{{define "base"}}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{template "title" .}} - Groupie Tracker</title>
    <link rel="stylesheet" href="/static/css/base.css">
    <link rel="icon" href="/favicon.ico">
    {{if .ExtraCSS}}
    <link rel="stylesheet" href="/static/css/{{.ExtraCSS}}">
    {{end}}
</head>

<body>
    <header class="site-header">
        <div class="container">
            <h1><a href="/">Groupie Tracker</a></h1>
            <nav class="main-nav">
                <a href="/">Home</a> •
                <a href="/artists">Artists</a> •
                <a href="/locations">Locations</a> •
                <a href="/search">Search</a>
            </nav>
        </div>
        
        <!-- Quick Search Bar -->
        <div class="quick-search-container">
            <div class="container">
                <form method="POST" action="/search" class="quick-search-form">
                    <div class="search-input-group">
                        <input type="text" 
                               name="q" 
                               placeholder="Quick search..." 
                               class="quick-search-input"
                               autocomplete="off">
                        <button type="submit" class="quick-search-btn">🔍</button>
                    </div>
                </form>
            </div>
        </div>
    </header>

    <main class="container">
        {{template "body" .}}
    </main>

    <footer class="site-footer">
        <div class="container">© 2025 Groupie Tracker</div>
    </footer>

    {{if .ExtraJS}}
    <script src="/static/js/{{.ExtraJS}}"></script>
    {{end}}
</body>

</html>
{{end}}