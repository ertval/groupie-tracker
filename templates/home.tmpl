{{define "title"}}{{.Title}}{{end}}

{{define "body"}}
<div class="page home">
    <header class="page-header">
        <h1 class="gradient-text">Welcome to Groupie Tracker</h1>
        <p class="muted">Discover your favorite artists, their concert locations, and tour dates</p>
    </header>

    <main class="page-body">
        <section class="stats-section">
            <div class="stats-grid">
                <div class="stat-card">
                    <h3>{{len .Artists}}</h3>
                    <p>Total Artists</p>
                </div>
                <div class="stat-card">
                    <h3>{{.TotalMembers}}</h3>
                    <p>Total Members</p>
                </div>
                <div class="stat-card">
                    <h3>{{.TotalLocations}}</h3>
                    <p>Concert Locations</p>
                </div>
            </div>
        </section>

        <section class="featured-artists">
            <h2>Featured Artists</h2>
            <div class="artist-grid">
                {{range $index, $artist := .Artists}}
                {{if lt $index 8}}
                <div class="artist-card">
                    <a href="/artists/{{$artist.Slug}}" class="artist-link">
                        <div class="artist-image-container">
                            <img src="{{$artist.Image}}" alt="{{$artist.Name}}" class="artist-image">
                        </div>
                        <div class="artist-info">
                            <h3 class="artist-name">{{$artist.Name}}</h3>
                            <p class="artist-details">
                                {{len $artist.Members}} member{{if ne (len $artist.Members) 1}}s{{end}} • 
                                Founded {{$artist.CreationYear}} • 
                                {{$artist.ConcertCount}} concert{{if ne $artist.ConcertCount 1}}s{{end}}
                            </p>
                            {{if $artist.Countries}}
                            <p class="artist-countries">
                                Performed in: {{join $artist.Countries ", "}}
                            </p>
                            {{end}}
                        </div>
                    </a>
                </div>
                {{end}}
                {{end}}
            </div>
            <div class="view-all">
                <a href="/artists" class="btn btn-primary">View All Artists</a>
            </div>
        </section>
    </main>
    <footer class="home-links muted">
        <p>
            <a href="/dev">Developer Tools</a> • 
            <a href="/health">Health Check</a>
        </p>
    </footer>
</div>
{{end}}