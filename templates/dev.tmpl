{{define "title"}}{{.Title}}{{end}}

{{define "body"}}
<div class="page dev-index">
    <header class="page-header">
        <h1>Developer Tools</h1>
        <p class="muted">Use these links to test error handling and other features.</p>
    </header>

    <main class="page-body">
        <ul class="dev-links">
            {{range .Links}}
            <li><a href="{{.Href}}" class="btn btn-outline">{{.Text}}</a></li>
            {{end}}
        </ul>

        <!-- Manual refresh form: posts to /api/refresh to trigger an async data refresh -->
        <section class="dev-refresh" style="margin-top:1.5rem;">
            <h2>Data Refresh</h2>
            <p class="muted">Trigger an immediate data refresh. This calls the server's <code>POST /api/refresh</code> endpoint and returns a 202 Accepted if started.</p>
            <form action="/api/refresh" method="post" style="display:inline-block;">
                <button type="submit" class="btn btn-primary">Trigger Manual Refresh</button>
            </form>
        </section>
    </main>
</div>
{{end}}