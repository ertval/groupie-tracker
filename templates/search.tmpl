{{define "title"}}Search{{end}}

{{define "body"}}
<div class="search-page">
    <!-- Search Form -->
    <div class="search-section">
        <h2 class="gradient-text">Search Artists</h2>
        <form method="POST" action="/search" class="search-form">
            <div class="search-input-container">
                <input type="text" 
                       name="q" 
                       value="{{.Query}}" 
                       placeholder="Search artists, members, locations, dates..." 
                       class="search-input"
                       list="search-suggestions"
                       autocomplete="off">
                <datalist id="search-suggestions">
                    {{range .Suggestions}}
                    <option value="{{.Text}}" label="{{.Description}}"></option>
                    {{end}}
                </datalist>
                <button type="submit" class="search-button">Search</button>
            </div>
            <small class="search-hint">💡 Start typing for suggestions, then press Enter or click Search</small>
        </form>
    </div>

    {{if .IsSearch}}
    <!-- Search Results -->
    <div class="results-section">
        <h3>Search Results {{if .Query}}for "{{.Query}}"{{end}}</h3>
        
        {{if .Results.Artists}}
        <p class="results-count">Found {{.Results.TotalResults}} artist{{if ne .Results.TotalResults 1}}s{{end}}</p>
        
        <div class="artists-grid">
            {{range .Results.Artists}}
            <div class="artist-card">
                <a href="/artists/{{.Slug}}" class="artist-link">
                    <div class="artist-image-container">
                        <img src="{{.Image}}" alt="{{.Name}}" class="artist-image">
                    </div>
                    <div class="artist-info">
                        <h3 class="artist-name">{{.Name}}</h3>
                        <p class="artist-details">
                            {{len .Members}} member{{if ne (len .Members) 1}}s{{end}} • 
                            Created {{.CreationYear}} • 
                            {{.ConcertCount}} concert{{if ne .ConcertCount 1}}s{{end}}
                        </p>
                        {{if .Countries}}
                        <p class="artist-countries">
                            Performed in: {{join .Countries ", "}}
                        </p>
                        {{end}}
                    </div>
                </a>
            </div>
            {{end}}
        </div>
        
        {{else}}
        <div class="no-results">
            <h4>No Results Found</h4>
            <p>No artists match your search criteria. Try:</p>
            <ul>
                <li>Using different keywords</li>
                <li>Checking spelling</li>
                <li>Searching for partial names</li>
                <li>Looking for band members</li>
                <li>Trying year or location searches</li>
            </ul>
        </div>
        {{end}}
    </div>
    {{end}}

    <!-- Advanced Filters -->
    <details class="filters-section">
        <summary>Advanced Filters</summary>
        
        <form method="POST" action="/search" class="filters-form">
            <input type="hidden" name="q" value="{{.Query}}">
            
            <!-- Year Range Filters -->
            <div class="filter-group">
                <h4>Creation Year ({{.FilterOptions.CreationYearMin}} - {{.FilterOptions.CreationYearMax}})</h4>
                <div class="range-slider-container">
                    <div class="range-labels">
                        <span>{{.FilterOptions.CreationYearMin}}</span>
                        <span>{{.FilterOptions.CreationYearMax}}</span>
                    </div>
                    <div class="range-inputs">
                        <label>
                            From: {{if .AppliedFilters.CreationYearFrom}}{{.AppliedFilters.CreationYearFrom}}{{else}}{{.FilterOptions.CreationYearMin}}{{end}}
                            <input type="range" 
                                   name="creationYearFrom" 
                                   min="{{.FilterOptions.CreationYearMin}}" 
                                   max="{{.FilterOptions.CreationYearMax}}" 
                                   value="{{if .AppliedFilters.CreationYearFrom}}{{.AppliedFilters.CreationYearFrom}}{{else}}{{.FilterOptions.CreationYearMin}}{{end}}"
                                   class="range-slider range-from">
                        </label>
                        <label>
                            To: {{if .AppliedFilters.CreationYearTo}}{{.AppliedFilters.CreationYearTo}}{{else}}{{.FilterOptions.CreationYearMax}}{{end}}
                            <input type="range" 
                                   name="creationYearTo" 
                                   min="{{.FilterOptions.CreationYearMin}}" 
                                   max="{{.FilterOptions.CreationYearMax}}" 
                                   value="{{if .AppliedFilters.CreationYearTo}}{{.AppliedFilters.CreationYearTo}}{{else}}{{.FilterOptions.CreationYearMax}}{{end}}"
                                   class="range-slider range-to">
                        </label>
                    </div>
                    <div class="range-values">
                        <small>Current selection: {{if .AppliedFilters.CreationYearFrom}}{{.AppliedFilters.CreationYearFrom}}{{else}}{{.FilterOptions.CreationYearMin}}{{end}} - {{if .AppliedFilters.CreationYearTo}}{{.AppliedFilters.CreationYearTo}}{{else}}{{.FilterOptions.CreationYearMax}}{{end}}</small>
                    </div>
                </div>
            </div>

            <!-- Member Count Filter -->
            <div class="filter-group">
                <h4>Number of Members</h4>
                <div class="checkbox-grid">
                    {{range .FilterOptions.MemberCounts}}
                    <label class="checkbox-label">
                        <input type="checkbox" 
                               name="memberCounts" 
                               value="{{.}}"
                               {{if contains $.AppliedFilters.MemberCounts .}}checked{{end}}>
                        {{.}} member{{if ne . 1}}s{{end}}
                    </label>
                    {{end}}
                </div>
            </div>

            <!-- Countries Filter -->
            <div class="filter-group">
                <h4>Countries</h4>
                <div class="checkbox-grid countries-grid">
                    {{range .FilterOptions.Countries}}
                    <label class="checkbox-label">
                        <input type="checkbox" 
                               name="countries" 
                               value="{{.}}"
                               {{if contains $.AppliedFilters.Countries .}}checked{{end}}>
                        {{.}}
                    </label>
                    {{end}}
                </div>
            </div>

            <div class="filter-actions">
                <button type="submit" class="filter-apply-btn">Apply Filters</button>
                <a href="/search{{if .Query}}?q={{.Query}}{{end}}" class="filter-clear-btn">Clear Filters</a>
            </div>
        </form>
    </details>

    <!-- Search Tips -->
    <div class="search-tips">
        <h4>Search Tips</h4>
        <ul>
            <li><strong>Artist Names:</strong> Search for "Queen", "Phil Collins", etc.</li>
            <li><strong>Band Members:</strong> Search for "Freddie Mercury", "Brian May", etc.</li>
            <li><strong>Locations:</strong> Search for "London", "New York", etc.</li>
            <li><strong>Years:</strong> Search for creation years like "1970" or album dates like "1973"</li>
            <li><strong>Partial Matches:</strong> "Phil" will find "Phil Collins" and "Philadelphia"</li>
        </ul>
    </div>
</div>
{{end}}