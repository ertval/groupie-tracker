{{define "title"}}{{.Artist.Name}}{{end}}

{{define "body"}}
<div class="page artist-detail">
    <header class="page-header">
        <div class="artist-header">
            <div class="artist-info-flex">
                <div class="artist-image-large">
                    <img src="{{.Artist.Image}}" alt="{{.Artist.Name}}" class="artist-image">
                </div>
                <div class="artist-basic-info">
                    <h1 class="gradient-text">{{.Artist.Name}}</h1>
                    <div class="artist-meta">
                        <p><strong>Creation Year:</strong> {{.Artist.CreationYear}}</p>
                        <p><strong>First Album:</strong> {{.Artist.FirstAlbum}}</p>
                        <p><strong>Members:</strong> {{len .Artist.Members}}</p>
                    </div>
                </div>
                <div class="artist-members">
                    <h3>Band Members</h3>
                    <div class="members-list">
                        {{range $index, $member := .Artist.Members}}
                        <span class="member-name">{{.}}</span>{{if lt $index (sub (len $.Artist.Members) 1)}}, {{end}}
                        {{end}}
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="page-body">

        <section class="artist-stats">
            <div class="stats-grid">
                <div class="stat-item">
                    <span class="stat-number">{{len .Artist.Members}}</span>
                    <span class="stat-label">Members</span>
                </div>
                {{if .Artist.Concerts}}
                <div class="stat-item">
                    <span class="stat-number">{{len .Artist.Countries}}</span>
                    <span class="stat-label">Countries</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">{{.Artist.ConcertCount}}</span>
                    <span class="stat-label">Total Concerts</span>
                </div>
                {{end}}
                <div class="stat-item">
                    <span class="stat-number">{{sub 2025 .Artist.CreationYear}}</span>
                    <span class="stat-label">Years Active</span>
                </div>
            </div>
        </section>

        {{if .Artist.Concerts}}
        <section class="concert-info">
            <h2>Concert History</h2>
            <div class="concerts-list">
                {{range .Artist.Concerts}}
                <div class="concert-item">
                    <span class="concert-date">{{.Date}}</span>
                    <span class="concert-location">{{.Location}}</span>
                </div>
                {{end}}
            </div>
        </section>
        {{else}}
        <section class="no-concerts">
            <h2>Concert Information</h2>
            <p class="muted">No concert information available for this artist.</p>
        </section>
        {{end}}

        <div class="navigation-links">
            <div class="back-to-artists">
                <a href="/artists" class="btn btn-secondary">← Back to Artists</a>
            </div>
        </div>
    </main>
</div>
{{end}}