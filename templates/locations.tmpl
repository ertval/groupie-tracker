{{define "title"}}{{.Title}}{{end}}

{{define "body"}}
<div class="page locations">
    <header class="page-header">
        <h1 class="gradient-text">Concert Locations</h1>
        {{if .IsFiltered}}
        <p class="muted results-count">Showing {{len .Locations}} filtered locations {{if .FilterDescription}}in {{.FilterDescription}}{{end}} out of {{.TotalLocations}} total locations</p>
        <div class="filter-status">
            <span class="filter-badge">Filtered {{if .FilterDescription}}by {{.FilterDescription}}{{end}}</span>
            <a href="/locations" class="clear-filters-link">Show All Locations</a>
        </div>
        {{else}}
        <p class="muted">Explore {{len .Locations}} unique concert venues around the world by Number of Concerts</p>
        {{end}}
    </header>

    <main class="page-body">
        <div class="content-wrapper">
            <!-- Main Content -->
            <div class="main-content">
                

                <!-- Filters Section (like search page) -->
                <details class="filters-section">
                    <summary>Advanced Filters</summary>
                    
                    <form method="POST" action="/locations" class="filters-form">
                        <!-- Concert Count Range -->
                        <div class="filter-group">
                            <h4>Concert Years</h4>
                            <div class="range-inputs">
                                <label>
                                    From:
                                    <input type="number" 
                                           name="yearFrom" 
                                           min="{{.FilterOptions.YearMin}}" 
                                           max="{{.FilterOptions.YearMax}}"
                                           value="{{if .AppliedFilters.YearFrom}}{{.AppliedFilters.YearFrom}}{{end}}"
                                           placeholder="{{.FilterOptions.YearMin}}">
                                </label>
                                <label>
                                    To:
                                    <input type="number" 
                                           name="yearTo" 
                                           min="{{.FilterOptions.YearMin}}" 
                                           max="{{.FilterOptions.YearMax}}"
                                           value="{{if .AppliedFilters.YearTo}}{{.AppliedFilters.YearTo}}{{end}}"
                                           placeholder="{{.FilterOptions.YearMax}}">
                                </label>
                            </div>
                        </div>

                        <!-- Artist Count Range -->
                        <!-- Artist Count Checkboxes -->
                        <div class="filter-group">
                            <h4>Number of Artists</h4>
                            <div class="checkbox-group">
                                {{range .FilterOptions.ArtistCounts}}
                                <label class="checkbox-label">
                                    <input type="checkbox" name="artistCounts" value="{{.}}" 
                                           {{if contains $.AppliedFilters.ArtistCounts .}}checked{{end}}>
                                    {{.}} artist{{if ne . 1}}s{{end}}
                                </label>
                                {{end}}
                            </div>
                        </div>

                        <!-- Concert Year Range -->
                        <div class="filter-group">
                            <h4>Concert Years</h4>
                            <div class="range-inputs">
                                <label>
                                    From:
                                    <input type="number" 
                                           name="yearFrom" 
                                           min="{{.FilterOptions.YearMin}}" 
                                           max="{{.FilterOptions.YearMax}}"
                                           value="{{if .AppliedFilters.YearFrom}}{{.AppliedFilters.YearFrom}}{{end}}"
                                           placeholder="{{.FilterOptions.YearMin}}">
                                </label>
                                <label>
                                    To:
                                    <input type="number" 
                                           name="yearTo" 
                                           min="{{.FilterOptions.YearMin}}" 
                                           max="{{.FilterOptions.YearMax}}"
                                           value="{{if .AppliedFilters.YearTo}}{{.AppliedFilters.YearTo}}{{end}}"
                                           placeholder="{{.FilterOptions.YearMax}}">
                                </label>
                            </div>
                        </div>

                        <div class="filter-actions">
                            <button type="submit" class="filter-apply-btn">Apply Filters</button>
                            <a href="/locations" class="filter-clear-btn">Clear Filters</a>
                        </div>
                    </form>
                </details>

                <section class="locations-grid">
                    {{if .Locations}}
                    <div class="locations-cards">
                        {{range .Locations}}
                        <div class="location-card">
                            <div class="location-info">
                                <h3 class="location-name"><a href="/locations/{{.Slug}}" class="location-name-link">{{.Name | title}}</a></h3>
                                <p class="location-stats">
                                    <span class="concert-count">{{.ConcertCount}} concerts</span> • 
                                    <span class="artist-count">{{len .Artists}} artists</span>
                                </p>
                                {{if gt (len .Artists) 0}}
                                <div class="location-artists muted">
                                    {{range $i, $artist := .Artists}}
                                    {{if gt $i 0}} {{end}}<span class="artist-with-count"><a href="/artists/{{$artist.Slug}}">{{$artist.Name}}</a>, ({{$artist.ConcertCount}})</span>
                                    {{end}}
                                </div>
                                {{end}}
                            </div>
                        </div>
                        {{end}}
                    </div>
                    {{else}}
                    <div class="no-results">
                        <h3>No locations found</h3>
                        <p>Try adjusting your search criteria or filters.</p>
                        <a href="/locations" class="btn btn-primary">Show All Locations</a>
                    </div>
                    {{end}}
                </section>
            </div>
        </div>
    </main>
</div>
{{end}}
