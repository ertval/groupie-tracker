{{define "title"}}{{.Title}}{{end}}

{{define "body"}}
<div class="page locations">
    <header class="page-header">
        <h1 class="gradient-text">Concert Locations</h1>
        {{if .IsFiltered}}
        <p class="muted results-count">Showing {{len .Locations}} filtered locations {{if .FilterDescription}}in {{.FilterDescription}}{{end}} out of {{.TotalLocations}} total locations</p>
        <div class="filter-status">
            <span class="filter-badge">Filtered {{if .FilterDescription}}by {{.FilterDescription}}{{end}}</span>
            <a href="/locations" class="clear-filters-link">Show All Locations</a>
        </div>
        {{else}}
        <p class="muted">Explore {{len .Locations}} unique concert venues around the world by Number of Concerts</p>
        {{end}}
    </header>

    <main class="page-body">
        <div class="content-wrapper">
            <!-- Main Content -->
            <div class="main-content">
                

                <!-- Filters Section (like search page) -->
                <details class="filters-section">
                    <summary>Advanced Filters</summary>
                    
                    <form method="POST" action="/locations" class="filters-form">
                        <!-- Concert Count Range -->
                        <div class="filter-group">
                            <h4>Concert Count</h4>
                            <div class="range-inputs">
                                <label>
                                    From:
                                    <input type="number" 
                                           name="concertCountFrom" 
                                           min="{{.LocationFilterOptions.ConcertCountMin}}" 
                                           max="{{.LocationFilterOptions.ConcertCountMax}}"
                                           value="{{if .AppliedFilters.ConcertCountFrom}}{{.AppliedFilters.ConcertCountFrom}}{{end}}"
                                           placeholder="{{.LocationFilterOptions.ConcertCountMin}}">
                                </label>
                                <label>
                                    To:
                                    <input type="number" 
                                           name="concertCountTo" 
                                           min="{{.LocationFilterOptions.ConcertCountMin}}" 
                                           max="{{.LocationFilterOptions.ConcertCountMax}}"
                                           value="{{if .AppliedFilters.ConcertCountTo}}{{.AppliedFilters.ConcertCountTo}}{{end}}"
                                           placeholder="{{.LocationFilterOptions.ConcertCountMax}}">
                                </label>
                            </div>
                        </div>

                        <!-- Artist Count Range -->
                        <div class="filter-group">
                            <h4>Artist Count</h4>
                            <div class="range-inputs">
                                <label>
                                    From:
                                    <input type="number" 
                                           name="artistCountFrom" 
                                           min="{{.LocationFilterOptions.ArtistCountMin}}" 
                                           max="{{.LocationFilterOptions.ArtistCountMax}}"
                                           value="{{if .AppliedFilters.ArtistCountFrom}}{{.AppliedFilters.ArtistCountFrom}}{{end}}"
                                           placeholder="{{.LocationFilterOptions.ArtistCountMin}}">
                                </label>
                                <label>
                                    To:
                                    <input type="number" 
                                           name="artistCountTo" 
                                           min="{{.LocationFilterOptions.ArtistCountMin}}" 
                                           max="{{.LocationFilterOptions.ArtistCountMax}}"
                                           value="{{if .AppliedFilters.ArtistCountTo}}{{.AppliedFilters.ArtistCountTo}}{{end}}"
                                           placeholder="{{.LocationFilterOptions.ArtistCountMax}}">
                                </label>
                            </div>
                        </div>

                        <!-- Concert Year Range -->
                        <div class="filter-group">
                            <h4>Concert Years</h4>
                            <div class="range-inputs">
                                <label>
                                    From:
                                    <input type="number" 
                                           name="concertYearFrom" 
                                           min="{{.LocationFilterOptions.ConcertYearMin}}" 
                                           max="{{.LocationFilterOptions.ConcertYearMax}}"
                                           value="{{if .AppliedFilters.ConcertYearFrom}}{{.AppliedFilters.ConcertYearFrom}}{{end}}"
                                           placeholder="{{.LocationFilterOptions.ConcertYearMin}}">
                                </label>
                                <label>
                                    To:
                                    <input type="number" 
                                           name="concertYearTo" 
                                           min="{{.LocationFilterOptions.ConcertYearMin}}" 
                                           max="{{.LocationFilterOptions.ConcertYearMax}}"
                                           value="{{if .AppliedFilters.ConcertYearTo}}{{.AppliedFilters.ConcertYearTo}}{{end}}"
                                           placeholder="{{.LocationFilterOptions.ConcertYearMax}}">
                                </label>
                            </div>
                        </div>

                        <!-- Country Checkboxes Filter -->
                        <div class="filter-group">
                            <h4>Countries</h4>
                            <div class="checkbox-grid countries-grid">
                                {{range .LocationFilterOptions.Countries}}
                                <label class="checkbox-label">
                                    <input type="checkbox" 
                                           name="countries" 
                                           value="{{.}}"
                                           {{if contains $.AppliedFilters.Countries .}}checked{{end}}>
                                    {{.}}
                                </label>
                                {{end}}
                            </div>
                        </div>

                        <div class="filter-actions">
                            <button type="submit" class="filter-apply-btn">Apply Filters</button>
                            <a href="/locations" class="filter-clear-btn">Clear Filters</a>
                        </div>
                    </form>
                </details>

                <section class="locations-grid">
                    <h2>{{if .IsFiltered}}Filtered Locations{{if .FilterDescription}} in {{.FilterDescription}}{{end}}{{else}}All Locations{{end}} (Sorted by Popularity)</h2>
                    {{if .Locations}}
                    <div class="locations-cards">
                        {{range .Locations}}
                        <div class="location-card">
                            <a href="/locations/{{.Slug}}" class="location-card-link">
                                <div class="location-info">
                                    <h3 class="location-name">{{.Name | title}}</h3>
                                    <p class="location-stats">
                                        <span class="concert-count">{{.TotalConcerts}} concerts</span> • 
                                        <span class="artist-count">{{.ArtistCount}} artists</span>
                                    </p>
                                    {{if gt (len .Artists) 0}}
                                    <div class="location-artists muted">
                                        {{range $i, $artistAtLocation := .Artists}}
                                        <span class="artist-with-count">{{if gt $i 0}}, {{end}}<a href="/artists/{{$artistAtLocation.Artist.Slug}}">{{$artistAtLocation.Artist.Name}}</a> ({{$artistAtLocation.ConcertCount}})</span>
                                        {{end}}
                                    </div>
                                    {{end}}
                                </div>
                            </a>
                        </div>
                        {{end}}
                    </div>
                    {{else}}
                    <div class="no-results">
                        <h3>No locations found</h3>
                        <p>Try adjusting your search criteria or filters.</p>
                        <a href="/locations" class="btn btn-primary">Show All Locations</a>
                    </div>
                    {{end}}
                </section>
            </div>
        </div>
    </main>
</div>
{{end}}
