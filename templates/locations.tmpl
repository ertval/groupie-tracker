<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{.Title}} - Groupie Tracker</title>
    <link rel="stylesheet" href="/static/css/base.css">
    {{if .ExtraCSS}}
    <link rel="stylesheet" href="/static/css/{{.ExtraCSS}}">
    {{end}}
</head>

<body>
    <header class="site-header">
        <div class="container">
            <h1><a href="/">Groupie Tracker</a></h1>
            <nav>
                <a href="/">Home</a> •
                <a href="/artists">Artists</a> •
                <a href="/locations">Locations</a>
            </nav>
        </div>
    </header>

    <main class="container">
        <div class="page locations">
            <header class="page-header">
                <h1>Concert Locations</h1>
                <p class="muted">Explore {{len .Locations}} unique concert venues around the world</p>
            </header>

            <main class="page-body">
                <section class="locations-stats">
                    <h2>Global Statistics</h2>
                    <div class="stats-grid">
                        <div class="stat-card">
                            <h3>{{len .Locations}}</h3>
                            <p>Total Locations</p>
                        </div>
                        <div class="stat-card">
                            <h3>{{.TotalCountries}}</h3>
                            <p>Countries</p>
                        </div>
                        <div class="stat-card">
                            <h3>{{.TotalConcerts}}</h3>
                            <p>Total Concerts</p>
                        </div>
                    </div>

                    <!-- Most Popular Locations: moved here to appear directly after the main stats -->
                    <section class="top-locations">
                        <h2>Most Popular Locations</h2>
                        <div class="top-locations-list">
                            {{range $index, $location := .TopLocations}}
                            {{if lt $index 10}}
                            <div class="top-location-item">
                                <span class="rank">{{add $index 1}}</span>
                                <span class="location-name"><a href="/locations/{{generateLocationSlug $location.Name}}">{{normalizeLocationName $location.Name}}</a></span>
                                <span class="stats">{{len $location.Artists}} artists • {{$location.TotalConcerts}} concerts</span>
                            </div>
                            {{end}}
                            {{end}}
                        </div>
                    </section>
                </section>

                <section class="locations-grid">
                    {{range .LocationStats}}
                    <div class="location-card" data-location="{{.Name}}">
                        <div class="location-info">
                            <h3 class="location-name"><a href="/locations/{{generateLocationSlug .Name}}">{{normalizeLocationName .Name}}</a></h3>
                            <div class="location-meta">
                                <p class="location-stats-inline"><span class="artist-count">{{len .Artists}} artists</span> • <span class="concert-count">{{.TotalConcerts}} concerts</span></p>
                            </div>
                        </div>
                        <div class="location-artists">
                                <h4>Artists who performed here:</h4>
                            <div class="artists-list">
                                {{range .Artists}}
                                <a href="/artists/{{.Slug}}" class="artist-link">{{.Name}}</a>
                                {{end}}
                            </div>
                        </div>
                    </div>
                    {{end}}
                </section>

                

                <section class="locations-map-placeholder">
                    <h2>World Map</h2>
                    <div class="map-container">
                        <p class="muted">Interactive map will be added by the JavaScript developer</p>
                        <div class="map-placeholder">
                            <span>🗺️ Concert Locations Map</span>
                        </div>
                    </div>
                </section>
                
            </main>
        </div>
    </main>

    <footer class="site-footer">
        <div class="container">© 2025 Groupie Tracker</div>
    </footer>

    {{if .ExtraJS}}
    <script src="/static/js/{{.ExtraJS}}"></script>
    {{end}}
</body>

</html>
