<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{.Title}} - Groupie Tracker</title>
    <link rel="stylesheet" href="/static/css/base.css">
    {{if .ExtraCSS}}
    <link rel="stylesheet" href="/static/css/{{.ExtraCSS}}">
    {{end}}
</head>

<body>
    <header class="site-header">
        <div class="container">
            <h1><a href="/">Groupie Tracker</a></h1>
            <nav>
                <a href="/">Home</a> •
                <a href="/artists">Artists</a> •
                <a href="/locations">Locations</a>
            </nav>
        </div>
    </header>

    <main class="container">
        <div class="page error">
            <main class="error-container">
                {{if eq .ErrorCode 404}}
                <div class="error-404">
                    <div class="error-icon">🔍</div>
                    <h1>404 - Page Not Found</h1>
                    <p class="error-message">The page you're looking for doesn't exist or has been moved.</p>
                    <div class="error-details">
                        <p>Requested URL: <code>{{.RequestedURL}}</code></p>
                    </div>
                    <div class="error-suggestions">
                        <h3>What you can do:</h3>
                        <ul>
                            <li>Check the URL for typos</li>
                            <li>Go back to the <a href="/">home page</a></li>
                            <li>Browse our <a href="/artists">artists collection</a></li>
                            <li>Explore <a href="/locations">concert locations</a></li>
                        </ul>
                    </div>
                </div>
                {{else if eq .ErrorCode 500}}
                <div class="error-500">
                    <div class="error-icon">⚠️</div>
                    <h1>500 - Internal Server Error</h1>
                    <p class="error-message">Something went wrong on our end. We're working to fix it!</p>
                    <div class="error-details">
                        {{if .Message}}
                        <p>Error details: <code>{{.Message}}</code></p>
                        {{end}}
                        <p>Time: {{.Timestamp}}</p>
                    </div>
                    <div class="error-suggestions">
                        <h3>What you can do:</h3>
                        <ul>
                            <li>Try refreshing the page</li>
                            <li>Go back to the <a href="/">home page</a></li>
                            <li>Try again in a few minutes</li>
                            <li>If the problem persists, please contact support</li>
                        </ul>
                    </div>
                </div>
                {{else}}
                <div class="error-generic">
                    <div class="error-icon">❌</div>
                    <h1>{{.ErrorCode}} - Error</h1>
                    <p class="error-message">{{.Message}}</p>
                    <div class="error-suggestions">
                        <ul>
                            <li>Go back to the <a href="/">home page</a></li>
                            <li>Browse our <a href="/artists">artists collection</a></li>
                        </ul>
                    </div>
                </div>
                {{end}}

                <div class="error-actions">
                    <a href="/" class="btn btn-primary">Go Home</a>
                    <button onclick="history.back()" class="btn btn-secondary">Go Back</button>
                    <button onclick="location.reload()" class="btn btn-outline">Refresh Page</button>
                </div>

                <div class="error-help">
                    <h3>Need Help?</h3>
                    <p>If you continue to experience issues, here are some helpful links:</p>
                    <div class="help-links">
                        <a href="/artists" class="help-link">
                            <span class="help-icon">🎵</span>
                            <span>Browse Artists</span>
                        </a>
                        <a href="/locations" class="help-link">
                            <span class="help-icon">📍</span>
                            <span>Concert Locations</span>
                        </a>
                        <a href="/health" class="help-link">
                            <span class="help-icon">💚</span>
                            <span>System Status</span>
                        </a>
                    </div>
                </div>
            </main>
        </div>
    </main>

    <footer class="site-footer">
        <div class="container">© 2025 Groupie Tracker</div>
    </footer>

    {{if .ExtraJS}}
    <script src="/static/js/{{.ExtraJS}}"></script>
    {{end}}
</body>

</html>
