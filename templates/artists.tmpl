{{define "title"}}{{.Title}}{{end}}

{{define "body"}}
<div class="page artists">
    <header class="page-header">
        <div class="header-content">
            <h1 class="gradient-text">All Artists</h1>
            {{if .IsFiltered}}
            <p class="muted results-count">Showing {{len .Artists}} filtered results out of {{.TotalArtists}} total artists</p>
            <div class="filter-status">
                <span class="filter-badge">Filtered</span>
                <a href="/artists" class="clear-filters-link">Show All Artists</a>
            </div>
            {{else}}
            <p class="muted results-count">Browse through our collection of {{len .Artists}} artists</p>
            {{end}}
        </div>
    </header>

    <main class="page-body">
        <div class="content-wrapper">
            <!-- Main Content -->
            <div class="main-content">
                <!-- Top Artists Section -->
                {{if not .IsFiltered}}
                <section class="top-artists">
                    <h2>Top Artists by Concerts Performed</h2>
                    <div class="top-artists-grid">
                        {{range $index, $artist := .TopArtists}}
                        <div class="top-artist-card">
                            <div class="rank">{{add $index 1}}</div>
                            <div class="artist-name"><a href="/artists/{{$artist.Slug}}">{{$artist.Name}}</a></div>
                            <div class="artist-stats">
                                <span class="concert-count">{{$artist.ConcertCount}} concerts</span> • 
                                <span class="member-count">{{len $artist.Members}} members</span>
                            </div>
                        </div>
                        {{end}}
                    </div>
                </section>
                {{end}}

                <!-- Filters Section (like search page) -->
                <details class="filters-section">
                    <summary>Advanced Filters</summary>
                    
                    <form method="POST" action="/artists" class="filters-form">
                        <!-- Creation Year Range -->
                        <div class="filter-group">
                            <h4>Creation Year ({{.FilterOptions.CreationYearMin}} - {{.FilterOptions.CreationYearMax}})</h4>
                            <div class="range-slider-container">
                                <div class="range-labels">
                                    <span>{{.FilterOptions.CreationYearMin}}</span>
                                    <span>{{.FilterOptions.CreationYearMax}}</span>
                                </div>
                                <div class="range-inputs">
                                    <label>
                                        From: {{if .AppliedFilters.CreationYearFrom}}{{.AppliedFilters.CreationYearFrom}}{{else}}{{.FilterOptions.CreationYearMin}}{{end}}
                                        <input type="range" 
                                               name="creationYearFrom" 
                                               min="{{.FilterOptions.CreationYearMin}}" 
                                               max="{{.FilterOptions.CreationYearMax}}"
                                               value="{{if .AppliedFilters.CreationYearFrom}}{{.AppliedFilters.CreationYearFrom}}{{else}}{{.FilterOptions.CreationYearMin}}{{end}}"
                                               class="range-slider range-from">
                                    </label>
                                    <label>
                                        To: {{if .AppliedFilters.CreationYearTo}}{{.AppliedFilters.CreationYearTo}}{{else}}{{.FilterOptions.CreationYearMax}}{{end}}
                                        <input type="range" 
                                               name="creationYearTo" 
                                               min="{{.FilterOptions.CreationYearMin}}" 
                                               max="{{.FilterOptions.CreationYearMax}}"
                                               value="{{if .AppliedFilters.CreationYearTo}}{{.AppliedFilters.CreationYearTo}}{{else}}{{.FilterOptions.CreationYearMax}}{{end}}"
                                               class="range-slider range-to">
                                    </label>
                                </div>
                                <div class="range-values">
                                    <small>Current: {{if .AppliedFilters.CreationYearFrom}}{{.AppliedFilters.CreationYearFrom}}{{else}}{{.FilterOptions.CreationYearMin}}{{end}} - {{if .AppliedFilters.CreationYearTo}}{{.AppliedFilters.CreationYearTo}}{{else}}{{.FilterOptions.CreationYearMax}}{{end}}</small>
                                </div>
                            </div>
                        </div>

                        <!-- First Album Year Range -->
                        <div class="filter-group">
                            <h4>First Album Year</h4>
                            <div class="range-inputs">
                                <label>
                                    From:
                                    <input type="number" 
                                           name="firstAlbumYearFrom" 
                                           min="{{.FilterOptions.FirstAlbumYearMin}}" 
                                           max="{{.FilterOptions.FirstAlbumYearMax}}"
                                           value="{{if .AppliedFilters.FirstAlbumYearFrom}}{{.AppliedFilters.FirstAlbumYearFrom}}{{end}}"
                                           placeholder="{{.FilterOptions.FirstAlbumYearMin}}">
                                </label>
                                <label>
                                    To:
                                    <input type="number" 
                                           name="firstAlbumYearTo" 
                                           min="{{.FilterOptions.FirstAlbumYearMin}}" 
                                           max="{{.FilterOptions.FirstAlbumYearMax}}"
                                           value="{{if .AppliedFilters.FirstAlbumYearTo}}{{.AppliedFilters.FirstAlbumYearTo}}{{end}}"
                                           placeholder="{{.FilterOptions.FirstAlbumYearMax}}">
                                </label>
                            </div>
                        </div>

                        <!-- Member Count Filter -->
                        <div class="filter-group">
                            <h4>Number of Members</h4>
                            <div class="checkbox-grid">
                                {{range .FilterOptions.MemberCounts}}
                                <label class="checkbox-label">
                                    <input type="checkbox" 
                                           name="memberCounts" 
                                           value="{{.}}"
                                           {{if contains $.AppliedFilters.MemberCounts .}}checked{{end}}>
                                    {{.}} member{{if ne . 1}}s{{end}}
                                </label>
                                {{end}}
                            </div>
                        </div>

                        <!-- Countries Filter -->
                        <div class="filter-group">
                            <h4>Countries</h4>
                            <div class="checkbox-grid countries-grid">
                                {{range .FilterOptions.Countries}}
                                <label class="checkbox-label">
                                    <input type="checkbox" 
                                           name="countries" 
                                           value="{{.}}"
                                           {{if contains $.AppliedFilters.Countries .}}checked{{end}}>
                                    {{.}}
                                </label>
                                {{end}}
                            </div>
                        </div>

                        <div class="filter-actions">
                            <button type="submit" class="filter-apply-btn">Apply Filters</button>
                            <a href="/artists" class="filter-clear-btn">Clear Filters</a>
                        </div>
                    </form>
                </details>

                <!-- Artists Grid -->
                <section class=\"artists-grid\" id=\"artists-grid\">
                    {{if .Artists}}
                    {{range .Artists}}
                    <div class=\"artist-card\" data-year=\"{{.CreationYear}}\" data-name=\"{{.Name}}\" 
                         data-members=\"{{len .Members}}\" data-first-album=\"{{.FirstAlbum}}\"
                         data-locations=\"{{range .Concerts}}{{.Location}} {{end}}\">
                        <a href=\"/artists/{{.Slug}}\" class=\"artist-link\">
                            <div class=\"artist-image-container\">
                                <img src=\"{{.Image}}\" alt=\"{{.Name}}\" class=\"artist-image\">
                            </div>
                            <div class=\"artist-info\">
                                <h3 class=\"artist-name\">{{.Name}}</h3>
                                <p class=\"artist-details\">
                                    {{len .Members}} member{{if ne (len .Members) 1}}s{{end}} • 
                                    Founded {{.CreationYear}} • 
                                    {{.ConcertCount}} concert{{if ne .ConcertCount 1}}s{{end}}
                                </p>
                                {{if .Countries}}
                                <p class="artist-countries">
                                    Performed in: {{join .Countries ", "}}
                                </p>
                                {{end}}
                            </div>
                        </a>
                    </div>
                    {{end}}
                    {{else}}
                    <div class=\"no-results\">
                        <h3>No artists found</h3>
                        <p>Try adjusting your search criteria or filters.</p>
                        <a href=\"/artists\" class=\"btn btn-primary\">Show All Artists</a>
                    </div>
                    {{end}}
                </section>
            </div>
        </div>
    </main>
</div>
{{end}}