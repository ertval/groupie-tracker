{{define "title"}}{{.Title}}{{end}}

{{define "body"}}
<div class="page artists">
    <header class="page-header">
        <h1>All Artists</h1>
        <p class="muted results-count">Browse through our collection of {{len .Artists}} artists</p>
    </header>

    <main class="page-body">
        <!-- Filter Section -->
        <section class="filters-section">
            <div class="filters-header">
                <h2>Filter Artists</h2>
                <button id="toggle-filters" class="filter-toggle" aria-expanded="false">
                    <span class="filter-icon">⚙️</span>
                    <span class="filter-text">Show Filters</span>
                </button>
            </div>

            <div id="filters-panel" class="filters-panel" style="display: none;">
                <form id="filter-form">
                    <!-- Creation Year Range Slider -->
                    <div class="filter-group">
                        <label class="filter-label">Creation Year</label>
                        <div class="slider-container">
                            <div class="slider-values">
                                <span id="creation-year-min">{{.FilterOptions.CreationYearMin}}</span>
                                <span id="creation-year-max">{{.FilterOptions.CreationYearMax}}</span>
                            </div>
                            <div class="range-slider">
                                <input type="range" id="creation-year-from" name="creationYearFrom" 
                                       min="{{.FilterOptions.CreationYearMin}}" 
                                       max="{{.FilterOptions.CreationYearMax}}" 
                                       value="{{.FilterOptions.CreationYearMin}}"
                                       class="range-input range-from">
                                <input type="range" id="creation-year-to" name="creationYearTo" 
                                       min="{{.FilterOptions.CreationYearMin}}" 
                                       max="{{.FilterOptions.CreationYearMax}}" 
                                       value="{{.FilterOptions.CreationYearMax}}"
                                       class="range-input range-to">
                            </div>
                            <div class="slider-labels">
                                <span>From: <span id="creation-year-from-value">{{.FilterOptions.CreationYearMin}}</span></span>
                                <span>To: <span id="creation-year-to-value">{{.FilterOptions.CreationYearMax}}</span></span>
                            </div>
                        </div>
                    </div>

                    <!-- First Album Year Range Slider -->
                    <div class="filter-group">
                        <label class="filter-label">First Album Year</label>
                        <div class="slider-container">
                            <div class="slider-values">
                                <span id="first-album-year-min">{{.FilterOptions.FirstAlbumYearMin}}</span>
                                <span id="first-album-year-max">{{.FilterOptions.FirstAlbumYearMax}}</span>
                            </div>
                            <div class="range-slider">
                                <input type="range" id="first-album-year-from" name="firstAlbumYearFrom" 
                                       min="{{.FilterOptions.FirstAlbumYearMin}}" 
                                       max="{{.FilterOptions.FirstAlbumYearMax}}" 
                                       value="{{.FilterOptions.FirstAlbumYearMin}}"
                                       class="range-input range-from">
                                <input type="range" id="first-album-year-to" name="firstAlbumYearTo" 
                                       min="{{.FilterOptions.FirstAlbumYearMin}}" 
                                       max="{{.FilterOptions.FirstAlbumYearMax}}" 
                                       value="{{.FilterOptions.FirstAlbumYearMax}}"
                                       class="range-input range-to">
                            </div>
                            <div class="slider-labels">
                                <span>From: <span id="first-album-year-from-value">{{.FilterOptions.FirstAlbumYearMin}}</span></span>
                                <span>To: <span id="first-album-year-to-value">{{.FilterOptions.FirstAlbumYearMax}}</span></span>
                            </div>
                        </div>
                    </div>

                    <!-- Member Count Checkboxes -->
                    <div class="filter-group">
                        <label class="filter-label">Number of Members</label>
                        <div class="checkbox-grid" id="member-count-checkboxes">
                            {{range .FilterOptions.MemberCounts}}
                            <div class="checkbox-item">
                                <input type="checkbox" id="members-{{.}}" name="memberCounts" value="{{.}}">
                                <label for="members-{{.}}">{{.}} member{{if ne . 1}}s{{end}}</label>
                            </div>
                            {{end}}
                        </div>
                    </div>

                    <!-- Country Checkboxes Filter -->
                    <div class="filter-group">
                        <label class="filter-label">Concert Countries</label>
                        <div class="checkbox-group" id="country-checkboxes">
                            {{range .FilterOptions.Countries}}
                            <div class="checkbox-item">
                                <input type="checkbox" id="country-{{.}}" name="countries" value="{{.}}">
                                <label for="country-{{.}}">{{.}}</label>
                            </div>
                            {{end}}
                        </div>
                    </div>

                    <!-- Filter Actions -->
                    <div class="filter-actions">
                        <button type="submit" class="btn btn-primary">Apply Filters</button>
                        <button type="button" id="clear-filters" class="btn btn-secondary">Clear All</button>
                        <button type="button" id="reset-filters" class="btn btn-tertiary">Reset</button>
                    </div>
                </form>
            </div>
        </section>

        <!-- Artists Grid -->
        <section class="artists-grid" id="artists-grid">
            {{range .Artists}}
            <div class="artist-card" data-year="{{.CreationYear}}" data-name="{{.Name}}" 
                 data-members="{{len .Members}}" data-first-album="{{.FirstAlbum}}"
                 data-locations="{{range .Concerts}}{{.Location}} {{end}}">
                <a href="/artists/{{.Slug}}">
                    <div class="artist-image-container">
                        <img src="{{.Image}}" alt="{{.Name}}" class="artist-image">
                    </div>
                    <div class="artist-info">
                        <h3>{{.Name}}</h3>
                        <p class="creation-year">{{.CreationYear}}</p>
                        <p class="first-album">First Album: {{.FirstAlbum}}</p>
                        <p class="members-count">{{len .Members}} members</p>
                        <div class="members-preview">
                            {{range $index, $member := .Members}}
                            {{if lt $index 3}}
                            <span class="member">{{$member}}</span>
                            {{end}}
                            {{end}}
                            {{if gt (len .Members) 3}}
                            <span class="more-members">+{{sub (len .Members) 3}} more</span>
                            {{end}}
                        </div>
                    </div>
                </a>
            </div>
            {{end}}
        </section>

        <div id="no-results" class="no-results" style="display: none;">
            <h3>No artists found</h3>
            <p>Try adjusting your search criteria or filters.</p>
        </div>

        <div id="loading" class="loading" style="display: none;">
            <div class="loading-spinner"></div>
            <p>Filtering artists...</p>
        </div>
    </main>
</div>

<script src="/static/js/filters.js"></script>
{{end}}