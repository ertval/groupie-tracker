{{define "title"}}{{.Location.Name | title}}{{end}}

{{define "body"}}
<div class="page location-detail">
    <header class="page-header">
        <h1>{{.Location.Name | title}}</h1>
        <div class="location-meta">
            <p><strong>{{.Location.ArtistCount}}</strong> artists performed here across <strong>{{.Location.TotalConcerts}}</strong> concerts.</p>
        </div>
    </header>

    <main class="page-body">
        <section class="artists-section">
            <h2>Artists Who Performed Here</h2>
            <div class="artists-grid">
                {{range .Artists}}
                <div class="artist-card">
                    <div class="artist-image">
                        <a href="/artists/{{.Slug}}">
                            <img src="{{.Image}}" alt="{{.Name}}" class="artist-img">
                        </a>
                    </div>
                    <div class="artist-info">
                        <h3 class="artist-heading">
                            <a href="/artists/{{.Slug}}" class="artist-link">{{.Name}}</a>
                        </h3>
                        <div class="artist-meta muted-small">
                            <strong>Creation Year:</strong> {{.CreationYear}} &nbsp; <strong>Members:</strong> {{len .Members}}
                        </div>
                        {{$dates := index .DatesAtLocation $.Location.Slug}}
                        {{if $dates}}
                        <p class="dates-list"><strong>Dates performed here:</strong> {{join $dates ", "}}</p>
                        {{end}}
                    </div>
                </div>
                {{end}}
            </div>
        </section>

        <div class="navigation-links">
            <a href="/locations" class="btn btn-secondary">← Back to Locations</a>
        </div>
    </main>
</div>
{{end}}
