{{define "title"}}{{.Location.Name | title}}{{end}}

{{define "body"}}
<div class="page location-detail">
    <header class="page-header">
        <h1 class="gradient-text">{{.Location.Name | title}}</h1>
        <div class="location-meta">
            <p><strong>{{len .Location.Artists}}</strong> Artists performed here across <strong>{{.Location.ConcertCount}}</strong> Concerts.</p>
          </div>
    </header>

    <main class="page-body">
        <section class="artists-section">
            <div class="artists-grid">
                {{range .Location.Artists}}
                <div class="artist-card">
                    <a href="/artists/{{.Slug}}" class="artist-link">
                        <div class="artist-info">
                            <h3 class="artist-name">{{.Name}}</h3>
                            <p class="artist-details">
                                {{.ConcertCount}} concert{{if ne .ConcertCount 1}}s{{end}} at this location
                            </p>
                        </div>
                    </a>
                </div>
                {{end}}
            </div>
        </section>

        <div class="navigation-links">
            <div class="location-nav-buttons">
                {{if .PrevLocation}}
                <a href="/locations/{{.PrevLocation.Slug}}" class="nav-btn">← {{.PrevLocation.Name}}</a>
                {{end}}
                {{if .NextLocation}}
                <a href="/locations/{{.NextLocation.Slug}}" class="nav-btn">{{.NextLocation.Name}} →</a>
                {{end}}
            </div>
            <div class="back-to-locations">
                <a href="/locations" class="btn btn-secondary">← Back to Locations</a>
            </div>
        </div>
    </main>
</div>
{{end}}
