{{define "title"}}{{.Location.Name | title}}{{end}}

{{define "body"}}
<div class="page location-detail">
    <header class="page-header">
        <h1>{{.Location.Name | title}}</h1>
        <div class="location-meta">
            <p><strong>{{.Location.ArtistCount}}</strong> Artists performed here across <strong>{{.Location.TotalConcerts}}</strong> Concerts.</p>
          </div>
    </header>

    <main class="page-body">
        <section class="artists-section">
            <h2>Artists Who Performed Here</h2>
            <div class="artists-grid">
                {{range .Artists}}
                <div class="artist-card">
                    <a href="/artists/{{.Artist.Slug}}" class="artist-link">
                        <div class="artist-image-container">
                            <img src="{{.Artist.Image}}" alt="{{.Artist.Name}}" class="artist-image">
                        </div>
                        <div class="artist-info">
                            <h3 class="artist-name">{{.Artist.Name}}</h3>
                            <p class="artist-details">
                                {{len .Artist.Members}} member{{if ne (len .Artist.Members) 1}}s{{end}} • 
                                Founded {{.Artist.CreationYear}} • 
                                {{.ConcertCount}} concert{{if ne .ConcertCount 1}}s{{end}}
                            </p>
                            {{if .Artist.Countries}}
                            <p class="artist-countries">
                                Performed in: {{join .Artist.Countries ", "}}
                            </p>
                            {{end}}
                            {{$dates := index .Artist.DatesAtLocation $.Location.Slug}}
                            {{if $dates}}
                            <p class="dates-list"><strong>Dates performed here:</strong> {{join $dates ", "}}</p>
                            {{end}}
                        </div>
                    </a>
                </div>
                {{end}}
            </div>
        </section>

        <div class="navigation-links">
            <a href="/locations" class="btn btn-secondary">← Back to Locations</a>
        </div>
    </main>
</div>
{{end}}
