<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{.Title}} - Groupie Tracker</title>
    <link rel="stylesheet" href="/static/css/base.css">
    {{if .ExtraCSS}}
    <link rel="stylesheet" href="/static/css/{{.ExtraCSS}}">
    {{end}}
</head>

<body>
    <header class="site-header">
        <div class="container">
            <h1><a href="/">Groupie Tracker</a></h1>
            <nav>
                <a href="/">Home</a> •
                <a href="/artists">Artists</a> •
                <a href="/locations">Locations</a>
            </nav>
        </div>
    </header>

    <main class="container">
        <div class="page location-detail">
            <header class="page-header">
                <h1>{{.DisplayName}}</h1>
                <div class="location-meta">
                    <p><strong>{{.Location.ArtistCount}}</strong> artists performed here</p>
                    <p><strong>{{.Location.ConcertCount}}</strong> concerts total</p>
                </div>
            </header>

            <main class="page-body">
                <section class="artists-section">
                    <h2>Artists who performed here</h2>
                    <div class="artists-grid">
                        {{range .Artists}}
                        <div class="artist-card">
                            <div class="artist-image">
                                <a href="/artists/{{.Slug}}">
                                    <img src="{{.Image}}" alt="{{.Name}}" class="artist-img">
                                </a>
                            </div>
                            <div class="artist-info">
                                <h3>
                                    <a href="/artists/{{.Slug}}" class="artist-link">{{.Name}}</a>
                                </h3>
                                <div class="artist-details">
                                    <span class="creation-year">{{.CreationYear}}</span>
                                    <span class="member-count">{{len .Members}} members</span>
                                </div>
                                {{if $.Location.ConcertDates}}
                                <div class="concert-dates">
                                    <h4>Concert Dates</h4>
                                    {{$dates := index $.Location.ConcertDates .ID}}
                                    {{if $dates}}
                                    <ul class="dates-list">
                                        {{range $dates}}
                                        <li class="date-item">{{.}}</li>
                                        {{end}}
                                    </ul>
                                    {{end}}
                                </div>
                                {{end}}
                            </div>
                        </div>
                        {{end}}
                    </div>
                </section>

                <section class="location-stats">
                    <h2>Statistics</h2>
                    <div class="stats-grid">
                        <div class="stat-item">
                            <span class="stat-number">{{.Location.ArtistCount}}</span>
                            <span class="stat-label">Artists</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-number">{{.Location.ConcertCount}}</span>
                            <span class="stat-label">Total Concerts</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-number">{{.Location.TotalShows}}</span>
                            <span class="stat-label">Total Shows</span>
                        </div>
                    </div>
                </section>

                <div class="navigation-links">
                    <a href="/locations" class="btn btn-secondary">← Back to Locations</a>
                </div>
            </main>
        </div>
    </main>

    <footer class="site-footer">
        <div class="container">© 2025 Groupie Tracker</div>
    </footer>

    {{if .ExtraJS}}
    <script src="/static/js/{{.ExtraJS}}"></script>
    {{end}}
</body>

</html>